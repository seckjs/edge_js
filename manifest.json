{
  "manifest_version": 3,
  "name": "Chaoxing Edge Assistant",
  "description": "在 Edge 中识别超星课程、作业、提交和题目，并提供主观题辅助批改能力。",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "permissions",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://*.chaoxing.com/*",
    "http://*.chaoxing.com/*",
    "https://*.chaoxing.com.cn/*",
    "http://*.chaoxing.com.cn/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "超星 Edge 助手",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.chaoxing.com/*",
        "http://*.chaoxing.com/*",
        "https://*.chaoxing.com.cn/*",
        "http://*.chaoxing.com.cn/*"
      ],
      "js": [
        "review-shared.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://*.chaoxing.com/*",
        "http://*.chaoxing.com/*",
        "https://*.chaoxing.com.cn/*",
        "http://*.chaoxing.com.cn/*"
      ]
    }
  ]
}
